    "deploymentEnv": "AZURE_OPENAI_IMAGE_DEPLOYMENT",
    "apiVersionEnv": "AZURE_OPENAI_IMAGE_API_VERSION",
    "defaultDeployment": "gpt-image-2",
    "defaultPromptFramework": "assets/images/prompt-frameworks.md",
    "note": "Deployment confirmed by Azure Foundry screenshot: gpt-image-2. Use this deployment for B route generation and optional A route background/polish. A route core images are HTML/CSS/SVG first."
  },
