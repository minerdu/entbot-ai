{
  "version": 4,
  "status": "generation-plan-v4-webp-delivery-png-qr",
  "rules": {
    "finalNames": "stable lowercase kebab-case without version suffix",
    "draftNames": "kebab-case with v01, v02, v03 suffix in _source or _exports",
    "preferredFinalFormats": {
      "uiScreenshots": "webp",
      "generatedDiagrams": "webp",
      "photos": "webp",
      "qrCodes": "png"
    },
    "responsiveDelivery": "non-QR website images use WebP srcset candidates; QR codes stay PNG",
    "standardWideCandidates": "1280w, 1920w, 2560w; height follows source ratio",
    "typeAProduction": "HTML/CSS/SVG deterministic composition first; gpt-image-2 only for optional background or polish",
    "typeBProduction": "real photo first; gpt-image-2 when no real source exists",
    "typeAStyle": "current page mockup shell plus clean Claude-style website demo visual with real readable Chinese content",
    "typeATextLanguage": "Chinese only, except necessary terms Agent, Skill, AI APP",
    "finalPngCanvas": "colored stage fills the image edge; no separate white artboard, outer shadow, or double-frame effect inside the exported PNG",
    "preflightRequired": "lock format, aspect ratio, display size, export size, template shell, source inputs, and text whitelist before generation"
  },
  "generationProvider": {
    "type": "azure-openai",
    "endpointEnv": "AZURE_OPENAI_IMAGE_ENDPOINT",
